        "body": {
          "mode": "raw",
          "raw": "{\n  \"moduleId\": {{moduleIdVideo}},\n  \"sortOrder\": 1,\n  \"required\": true,\n  \"unlockCondition\": \"DEFAULT\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/milestones/{{milestoneId}}/modules",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "milestones",
            "{{milestoneId}}",
            "modules"
          ]
        }
      }
    },
