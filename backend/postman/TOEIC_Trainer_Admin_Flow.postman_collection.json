{
  "info": {
    "name": "TOEIC Trainer - Admin Learning Path Flow",
    "description": "Collection test nhanh flow: login admin -> tao learning path -> tao milestone -> tao module -> gan module vao milestone -> tao video/practice/flashcard.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.environment.set('adminToken', json.data.accessToken);",
              "pm.test('Co accessToken', function () { pm.expect(json.data.accessToken).to.be.a('string').and.not.empty; });"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - Create Learning Path",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"{{pathCode}}\",\n  \"title\": \"{{pathTitle}}\",\n  \"description\": \"Lo trinh test tu Postman\",\n  \"targetScore\": {{targetScore}},\n  \"active\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/learning-paths",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "learning-paths"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.environment.set('learningPathId', json.data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - Create Milestone",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Giai doan 1\",\n  \"description\": \"Nen tang cho muc tieu {{targetScore}}\",\n  \"sortOrder\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/learning-paths/{{learningPathId}}/milestones",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "learning-paths",
            "{{learningPathId}}",
            "milestones"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.environment.set('milestoneId', json.data.id);"
            ]
          }
        }
      ]
    },
